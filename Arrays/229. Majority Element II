//Better approach by Hashing .
// time complexity = O(nlogn) for ordered map and O(n) for best case of unordered map.
//space complexity = O(n).

class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
        vector<int>ls;
        map<int,int>mpp;
        int mini = (int)(nums.size()/3)+1;
        for(int i=0;i<nums.size();i++){
            mpp[nums[i]]++;
            if(mpp[nums[i]]==mini) ls.push_back(nums[i]);
            if(ls.size()==2) break;
        } 
        return ls;
        
    }
};


//optimal approach:
//time complexity:O(2n)=O(n).
//space complexity:O(1).


class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
       int n=nums.size();   //size
       int cnt1=0,cnt2=0;   //intialize counter 
       int el1=INT_MIN,el2 = INT_MIN; // intialize least number in integer datatype.
       int mini = (int)(n/3)+1;   // minimun times the element appears.
       for(int i=0;i<n;i++){
        if(cnt1==0 && el2!=nums[i]) {
            cnt1=1;
            el1=nums[i];
        }
        else if(cnt2==0 && el1!=nums[i]){
            cnt2=1;
            el2=nums[i];
        }
        else if(el1==nums[i]) cnt1++;
        else if(el2 == nums[i]) cnt2++;
        else{
            cnt1--;
            cnt2--;
        }
       }
       //mannual check that the elements el1 and el2 occurs greater than floor(n/3) times.
       cnt1=0,cnt2=0;
       vector<int>ls;
       for(int i=0;i<n;i++){
        if(el1 == nums[i])cnt1++;
        if(el2 == nums[i])cnt2++;
       }
       if(cnt1 >= mini)ls.push_back(el1);
       if(cnt2 >=mini) ls.push_back(el2);
       sort(ls.begin(),ls.end());
       return ls;
        
    }
};













