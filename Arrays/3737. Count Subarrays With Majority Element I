class Solution {
public:
    int countMajoritySubarrays(vector<int>& nums, int target) {

        int n = nums.size();
        long long ans = 0;

        for (int i = 0; i < n; i++) {

            int sum = 0;  // +1 for target, -1 otherwise

            for (int j = i; j < n; j++) {

                if (nums[j] == target)
                    sum += 1;
                else
                    sum -= 1;

                // Positive sum => target is majority
                if (sum > 0)
                    ans++;
            }
        }

        return ans;
    }
};
