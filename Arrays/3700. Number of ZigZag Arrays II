class Solution {
public:
    static const int MOD = 1e9 + 7;
    using ll = long long;
    using Matrix = vector<vector<ll>>;

    // Matrix multiplication
    Matrix multiply(Matrix &A, Matrix &B) {
        int sz = A.size();
        Matrix C(sz, vector<ll>(sz, 0));

        for (int i = 0; i < sz; i++) {
            for (int k = 0; k < sz; k++) {
                if (A[i][k] == 0) continue;

                for (int j = 0; j < sz; j++) {
                    if (B[k][j] == 0) continue;

                    C[i][j] =
                        (C[i][j] + A[i][k] * B[k][j]) % MOD;
                }
            }
        }
        return C;
    }

    // Binary exponentiation of matrix
    Matrix power(Matrix base, long long exp) {
        int sz = base.size();

        Matrix res(sz, vector<ll>(sz, 0));
        for (int i = 0; i < sz; i++)
            res[i][i] = 1;

        while (exp) {
            if (exp & 1)
                res = multiply(res, base);

            base = multiply(base, base);
            exp >>= 1;
        }

        return res;
    }

    int zigZagArrays(int n, int l, int r) {
        int m = r - l + 1;

        // Number of states = up + down
        int S = 2 * m;

        // Base DP for length = 2
        vector<ll> dp(S, 0);

        for (int v = 0; v < m; v++) {
            dp[v] = v;             // up[v]
            dp[m + v] = m - v - 1; // down[v]
        }

        // n = 2 case (not needed by constraints, but safe)
        if (n == 2) {
            ll ans = 0;
            for (ll x : dp)
                ans = (ans + x) % MOD;
            return ans;
        }

        // Transition matrix
        Matrix T(S, vector<ll>(S, 0));

        for (int u = 0; u < m; u++) {

            // up[u] -> down[v], v < u
            for (int v = 0; v < u; v++) {
                T[m + v][u] = 1;
            }

            // down[u] -> up[v], v > u
            for (int v = u + 1; v < m; v++) {
                T[v][m + u] = 1;
            }
        }

        // Apply transitions (n-2) times
        Matrix P = power(T, n - 2);

        vector<ll> ansVec(S, 0);

        for (int i = 0; i < S; i++) {
            for (int j = 0; j < S; j++) {
                ansVec[i] =
                    (ansVec[i] + P[i][j] * dp[j]) % MOD;
            }
        }

        ll ans = 0;
        for (ll x : ansVec)
            ans = (ans + x) % MOD;

        return (int)ans;
    }
};
