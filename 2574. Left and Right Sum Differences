#c++ 
//Time Complexity = O(n)
// Space Complexity =O(n)

class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        vector<int>leftSum;
        vector<int> rightSum;

        int ls =0;
        int n=nums.size();
        for(int i=0;i<n;i++){
            leftSum.push_back(ls);
            ls +=nums[i];
        } 
        int rs=0;
        for(int i=n-1;i>=0;i--){
            rightSum.push_back(rs);
            rs += nums[i];
        }
        reverse(rightSum.begin(),rightSum.end());

        vector<int> answer;

        for(int i=0;i<n;i++){
            answer.push_back(abs(leftSum[i] - rightSum[i]));
        }
        return answer;
    }
};

