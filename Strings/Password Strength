c++

class Solution {
public:
    int passwordStrength(string password) {
        unordered_set<char> seen(password.begin(),password.end());
        int score=0;
        for(char c:seen){
            if(islower(c)) score+=1;
            else if(isupper(c)) score+=2;
            else if(isdigit(c)) score+=3;
            else score+=5;
        }
        return score;
        
        
    }
};
