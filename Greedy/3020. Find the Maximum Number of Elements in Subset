// HASHMAP + GREEDY

class Solution {
public:
    int maximumLength(vector<int>& nums) {

        unordered_map<long long, int> freq;

        for (int x : nums)
            freq[x]++;

        int ans = 1;

        // Special case for 1
        if (freq.count(1))
            ans = max(ans, freq[1] % 2 ? freq[1] : freq[1] - 1);

        for (auto &[start, cnt] : freq) {

            if (start == 1)
                continue;

            long long x = start;
            int len = 0;

            while (freq.count(x)) {

                if (freq[x] >= 2) {
                    len += 2;

                    if (x > 1000000000LL / x)
                        break;

                    x *= x;
                }
                else {
                    len++;
                    break;
                }
            }

            // Remove one extra counted copy
            if (len % 2 == 0)
                len--;

            ans = max(ans, len);
        }

        return ans;
    }
};
