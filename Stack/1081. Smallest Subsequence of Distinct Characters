class Solution {
public:
    string smallestSubsequence(string s) {
        int n=s.size();
        vector<int>lastIndex(26,0);
        for(int i=0;i<n;i++){
            lastIndex[s[i]-'a']=i;
        }
        vector<bool>instack(26,false);
        string stack;
        for(int i=0;i<n;i++){
            char c =s[i];
            if(instack[c-'a']) continue;
            while(!stack.empty() && stack.back() > c && lastIndex[stack.back()-'a'] >i){
                instack[stack.back()- 'a']=false;
                stack.pop_back();
            }
            stack.push_back(c);
            instack[c-'a']=true;
        }
        return stack;
        
    }
};
