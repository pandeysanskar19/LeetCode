class Solution {
public:
    int findMin(vector<int>& nums) {
        int mini=INT_MAX;
        int n=nums.size();
        int low=0;int high=n-1;
        while(low<=high){
            int mid=low+(high-low)/2;
            if(n==1) return nums[0];
            if(nums[low]<=nums[high]){
                mini=min(nums[low],mini);
                break;
            }

            if(nums[low]<=nums[mid]){
                mini=min(nums[low],mini);
                low=mid+1;
            }
            else{
                high=mid-1;
                mini=min(nums[mid],mini);
                
            }
        }
        return mini;
    }
};
