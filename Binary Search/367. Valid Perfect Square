Time complexity : O(log n)
Space complexity : O(1)

class Solution {
public:
    bool isPerfectSquare(int num) {
        int low=1;int high=num;long long ans=1;
        while(low<=high){
            long long mid=low+(high-low)/2;
            if(mid * mid<=num){
                ans=mid;
                low=mid+1;
            }
            else{
                high=mid-1;
            }
        }  
        if(ans * ans==num){
            return true;
        }   
        return false;
    }
};
